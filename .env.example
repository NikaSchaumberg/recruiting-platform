# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Microsoft Teams (Incoming Webhook URLs)
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/...       # HR channel — receives all new applications
TEAMS_HM_WEBHOOK_URL=https://your-org.webhook.office.com/...    # Hiring manager channel — optional, receives per-role notifications

# Microsoft Graph API (for Outlook email notifications and Teams DMs)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
GRAPH_SENDER_EMAIL=sender@yourcompany.com   # Real M365 licensed user that sends all emails/DMs (e.g. nschaumberg@exxircapital.com)
HR_INBOX_EMAIL=hr@yourcompany.com           # Shared mailbox where HR notification emails are delivered

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Webhook
WEBHOOK_SECRET=your-webhook-secret
`